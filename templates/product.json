{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": { "type": "title", "settings": {} },
        "price": { "type": "price", "settings": {} },
        "rating": { "type": "rating", "settings": {} },
        "variant_picker": { "type": "variant_picker", "settings": { "picker_type": "button" } },
        "quantity_selector": { "type": "quantity_selector", "settings": {} },
        "buy_buttons": { "type": "buy_buttons", "settings": { "show_dynamic_checkout": true, "show_gift_card_recipient": false } },
        "delivery_meta": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class='ww-product-meta'><p><strong>Delivery estimate:</strong> 3-7 business days</p><p><strong>COD availability:</strong> Available for eligible PIN codes</p><p><strong>Offer:</strong> Extra 5% on prepaid orders</p></div>"
          }
        },
        "benefits": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "leaf",
            "heading_1": "Soft",
            "icon_2": "heart",
            "heading_2": "Skin friendly",
            "icon_3": "check_mark",
            "heading_3": "Durable"
          }
        },
        "description": { "type": "description", "settings": {} },
        "wash_care": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Material & Wash Care",
            "icon": "check_mark",
            "content": "<p>Premium cotton blend. Machine wash cold, gentle cycle, do not bleach, tumble dry low, warm iron if needed.</p>"
          }
        },
        "faq_1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "FAQ: Is this suitable for all seasons?",
            "icon": "question_mark",
            "content": "<p>Yes. The breathable weave supports comfort in both warm and mild weather conditions.</p>"
          }
        },
        "faq_2": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "FAQ: What is your return policy?",
            "icon": "question_mark",
            "content": "<p>Easy returns are available as per policy guidelines on unused products within the return window.</p>"
          }
        },
        "share": { "type": "share", "settings": { "share_label": "Share" } },
        "complementary": {
          "type": "complementary",
          "settings": {
            "block_heading": "Complete the look",
            "products_to_show": 4,
            "show_view_all": true,
            "show_vendor": false,
            "show_rating": false
          }
        }
      },
      "block_order": [
        "title",
        "price",
        "rating",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "delivery_meta",
        "benefits",
        "description",
        "wash_care",
        "faq_1",
        "faq_2",
        "share",
        "complementary"
      ],
      "settings": {
        "enable_sticky_info": true,
        "media_size": "large",
        "constrain_to_viewport": false,
        "media_fit": "cover",
        "gallery_layout": "thumbnail_slider",
        "media_position": "left",
        "image_zoom": "hover",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 20,
        "padding_bottom": 20
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "background-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 12,
        "padding_bottom": 36
      }
    }
  },
  "order": ["main", "related-products"]
}
