{{ 'component-slider.css' | asset_url | stylesheet_tag }}

<section class="woodwhite-home color-{{ section.settings.color_scheme }} gradient">
  <div class="ww-home-topbar">
    <div class="page-width ww-home-topbar__inner">
      <nav class="ww-home-topbar__menu" aria-label="Primary">
        <a href="{{ section.settings.nav_link_1 }}">{{ section.settings.nav_label_1 }}</a>
        <a href="{{ section.settings.nav_link_2 }}">{{ section.settings.nav_label_2 }}</a>
        <a href="{{ section.settings.nav_link_3 }}">{{ section.settings.nav_label_3 }}</a>
        <a href="{{ section.settings.nav_link_4 }}">{{ section.settings.nav_label_4 }}</a>
      </nav>
      <p class="ww-home-topbar__brand">WOODWHITE</p>
      <div class="ww-home-topbar__icons" aria-hidden="true">
        <span>⌕</span>
        <span>♡</span>
        <span>🛒</span>
        <span>◯</span>
      </div>
    </div>
  </div>

  <div class="ww-hero">
    {% if section.settings.hero_image != blank %}
      {{ section.settings.hero_image | image_url: width: 2200 | image_tag: class: 'ww-hero__image', loading: 'eager', alt: section.settings.heading }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg ww-hero__image' }}
    {% endif %}

    <div class="page-width ww-hero__content-wrap">
      <div class="ww-hero__content">
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.subheading }}</p>
        <a href="{{ section.settings.primary_button_link }}" class="button">{{ section.settings.primary_button_label }}</a>
      </div>
    </div>
  </div>

  <div class="page-width ww-category-strip">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a href="{{ block.settings.link }}" class="ww-category-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          <div class="ww-category-card__body">
            <h3>{{ block.settings.title }}</h3>
            <span>Shop Now →</span>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>

  <div class="page-width ww-sale">
    <h2>{{ section.settings.flash_heading }}</h2>
    <div class="ww-sale__timer" aria-label="Flash sale countdown">
      <div><strong>{{ section.settings.timer_days }}</strong><span>Days</span></div>
      <div><strong>{{ section.settings.timer_hours }}</strong><span>Hours</span></div>
      <div><strong>{{ section.settings.timer_mins }}</strong><span>Mins</span></div>
      <div><strong>{{ section.settings.timer_secs }}</strong><span>Secs</span></div>
    </div>
    <div class="ww-sale__grid">
      {% assign flash_collection = collections[section.settings.flash_collection] %}
      {% if flash_collection != blank %}
        {% for product in flash_collection.products limit: 2 %}
          <article class="ww-sale-card">
            <a href="{{ product.url }}" class="ww-sale-card__img">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: product.title }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </a>
            <div class="ww-sale-card__info">
              <p class="ww-sale-card__offer">{{ section.settings.flash_offer_text }}</p>
              <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <p class="ww-price">
                <span>{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}<s>{{ product.compare_at_price | money }}</s>{% endif %}
              </p>
              <a class="button" href="{{ product.url }}">{{ section.settings.flash_button_label }}</a>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <p>Select a flash sale collection in this section settings.</p>
      {% endif %}
    </div>
  </div>

  <div class="page-width ww-products">
    <div class="ww-products__header">
      <h2>{{ section.settings.best_sellers_heading }}</h2>
    </div>
    <div class="ww-products__grid">
      {% assign best_collection = collections[section.settings.best_sellers_collection] %}
      {% if best_collection != blank %}
        {% for product in best_collection.products limit: 4 %}
          <article class="ww-product-card">
            <a href="{{ product.url }}" class="ww-product-card__img">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
              {% else %}
                {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </a>
            <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <p class="ww-product-card__meta">★★★★★ <span>{{ product.metafields.reviews.rating.value | default: section.settings.default_rating }}</span></p>
            <p class="ww-price"><span>{{ product.price | money }}</span></p>
            <a class="button" href="{{ product.url }}">{{ section.settings.best_sellers_button_label }}</a>
          </article>
        {% endfor %}
      {% else %}
        <p>Select a best sellers collection in this section settings.</p>
      {% endif %}
    </div>
  </div>

  <div class="ww-testimonials">
    <div class="page-width">
      <h2>{{ section.settings.testimonials_heading }}</h2>
      <div class="ww-testimonials__grid">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <blockquote {{ block.shopify_attributes }}>
              <p>“{{ block.settings.quote }}”</p>
              <cite>– {{ block.settings.author }}</cite>
            </blockquote>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="page-width ww-faq">
    <h2>{{ section.settings.faq_heading }}</h2>
    {% for block in section.blocks %}
      {% if block.type == 'faq' %}
        <details {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <p>{{ block.settings.answer }}</p>
        </details>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "WOODWHITE Home",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "text", "id": "nav_label_1", "label": "Menu label 1", "default": "Shop" },
    { "type": "url", "id": "nav_link_1", "label": "Menu link 1" },
    { "type": "text", "id": "nav_label_2", "label": "Menu label 2", "default": "About Us" },
    { "type": "url", "id": "nav_link_2", "label": "Menu link 2" },
    { "type": "text", "id": "nav_label_3", "label": "Menu label 3", "default": "Journal" },
    { "type": "url", "id": "nav_link_3", "label": "Menu link 3" },
    { "type": "text", "id": "nav_label_4", "label": "Menu label 4", "default": "Contact" },
    { "type": "url", "id": "nav_link_4", "label": "Menu link 4" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Elevate Your Sleep Experience" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Experience the ultimate comfort with our curated collection of premium bedding and home essentials." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "primary_button_label", "label": "Primary CTA label", "default": "Shop Now" },
    { "type": "url", "id": "primary_button_link", "label": "Primary CTA link" },
    { "type": "text", "id": "flash_heading", "label": "Flash sale heading", "default": "Flash Sale" },
    { "type": "collection", "id": "flash_collection", "label": "Flash sale collection" },
    { "type": "text", "id": "flash_offer_text", "label": "Flash offer text", "default": "Limited time offer on premium bedding set" },
    { "type": "text", "id": "flash_button_label", "label": "Flash button label", "default": "Shop Sale" },
    { "type": "text", "id": "timer_days", "label": "Timer days", "default": "04" },
    { "type": "text", "id": "timer_hours", "label": "Timer hours", "default": "12" },
    { "type": "text", "id": "timer_mins", "label": "Timer mins", "default": "30" },
    { "type": "text", "id": "timer_secs", "label": "Timer secs", "default": "45" },
    { "type": "text", "id": "best_sellers_heading", "label": "Best sellers heading", "default": "Best Sellers" },
    { "type": "collection", "id": "best_sellers_collection", "label": "Best sellers collection" },
    { "type": "text", "id": "default_rating", "label": "Fallback rating", "default": "4.9" },
    { "type": "text", "id": "best_sellers_button_label", "label": "Best seller button label", "default": "Add to Cart" },
    { "type": "text", "id": "testimonials_heading", "label": "Testimonials heading", "default": "Testimonial" },
    { "type": "text", "id": "faq_heading", "label": "FAQ heading", "default": "Frequently Asked Questions" }
  ],
  "blocks": [
    {"type":"category","name":"Category","limit":3,"settings":[{"type":"image_picker","id":"image","label":"Image"},{"type":"text","id":"title","label":"Title","default":"Bed Sheets"},{"type":"url","id":"link","label":"Link"}]},
    {"type":"testimonial","name":"Testimonial","limit":4,"settings":[{"type":"textarea","id":"quote","label":"Quote","default":"The softest sheets I've ever owned. Completely transformed my sleep."},{"type":"text","id":"author","label":"Author","default":"Sarah J."}]},
    {"type":"faq","name":"FAQ","limit":6,"settings":[{"type":"text","id":"question","label":"Question","default":"What materials are used in your bedding?"},{"type":"textarea","id":"answer","label":"Answer","default":"Our bedding uses breathable premium cotton, linen blends, and quality performance fabrics depending on the product."}]}
  ],
  "presets": [{
    "name": "WOODWHITE Home",
    "blocks": [
      {"type":"category","settings":{"title":"Bed Sheets"}},
      {"type":"category","settings":{"title":"Duvet Covers"}},
      {"type":"category","settings":{"title":"Pillows"}},
      {"type":"testimonial"},
      {"type":"testimonial","settings":{"author":"Koven H."}},
      {"type":"faq"},
      {"type":"faq","settings":{"question":"How do I care for my products?"}}
    ]
  }]
}
{% endschema %}
